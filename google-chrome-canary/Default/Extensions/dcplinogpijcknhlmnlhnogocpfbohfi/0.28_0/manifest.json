{
   "action": {
      "default_height": 500,
      "default_popup": "popup.html",
      "default_title": "Open Graphite",
      "default_width": 300
   },
   "background": {
      "service_worker": "background.js"
   },
   "description": "Help navigate from GitHub PRs to Graphite",
   "externally_connectable": {
      "matches": [ "https://app.graphite.com/*", "https://app.graphite.dev/*", "https://localhost:3000/*" ]
   },
   "host_permissions": [ "*://github.com/*", "*://app.graphite.com/*", "*://app.graphite.dev/*" ],
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "48": "icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Graphite",
   "optional_host_permissions": [ "\u003Call_urls>" ],
   "permissions": [ "scripting", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.28"
}
