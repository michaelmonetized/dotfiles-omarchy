alias nano='nvim'
alias micro='nvim'
alias ls='eza --color=always --long --git --icons=always --no-filesize --no-time --no-permissions --no-user'
alias lt='eza --tree --git-ignore --color=always --icons=always --no-filesize --no-time --no-permissions --no-user'
alias la='eza --color=always --long --git --icons=always --extended --total-size --all'
alias lg='lazygit'
alias c='clear'
alias cxd="codex --dangerously-bypass-approvals-and-sandbox --enable goals"
alias cld="claude --dangerously-skip-permissions"
alias i='sudo pacman -Syy "$@" --noconfirm --overwrite "*"'
alias s='sudo pacman -Ssyy "$@"'
alias gmd="gemini -y"
alias np="~/bin/newproject" #pops an fzf menu with options ( hustlestack,  swift,  cli,  hustlestack-web-native-monorepo)
alias npr='~/bin/stack "$@"'
alias ni='gh issue create "$@"'
alias m='gt merge -q "$@"'
alias no='openclaw tui'
alias nob='openclaw browser "$@"'
alias nsh='open "https://sheets.new"'
alias ndc='open "htts://docs.new"'
alias nv='nvim "$@"'
alias p='cxd exec "$@"'
unalias cb 2>/dev/null
cb() {
  git remote show origin | awk '/HEAD branch/ {print $NF}'
}
unalias mpr 2>/dev/null
mpr() {
  gh pr merge -sd && \
  git checkout "$(cb)" && \
  git pull
}
alias o='open'
alias q='exit'
alias ot='NODE_OPTIONS=--use-system-ca openclaw tui'
alias t='tmux'
alias ta='tmux a'
